    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "bundle": "npx react-native bundle --platform android --dev false --entry-file index.js  --bundle-output android/app/src/main/assets/index.android.bundle --assets-dest android/app/src/main/res/",
    "release-apk": "npm run bundle && cd android && ./gradlew assembleRelease",
    "build-dev-android": "cp ./.env.dev ./.env && npx react-native run-android",
    "build-dev-ios": "cp ./.env.dev ./.env && npx react-native run-ios",
    "build-prod-android": "cp ./.env.prod ./.env && npx react-native run-android",
    "build-prod-ios": "cp ./.env.prod ./.env && npx react-native run-ios",
    "debug": "open 'rndebugger://set-debugger-loc?host=localhost&port=19001",
    "build:ios": "react-native bundle --entry-file='index.js' --bundle-output='./ios/main.jsbundle' --dev=false --platform='ios'"
  },
